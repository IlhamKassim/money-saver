{
  "name": "money-saver",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:server": "bun run --filter @money-saver/server dev",
    "dev:client": "bun run --filter @money-saver/client dev",
    "db:generate": "bun run --filter @money-saver/db generate",
    "db:migrate": "bun run --filter @money-saver/db migrate",
    "db:studio": "bun run --filter @money-saver/db studio",
    "seed": "bun run --filter @money-saver/db seed",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/bun": "latest"
  }
}
